table Actual_Demand_Monthly
	lineageTag: f7a55b73-c505-4116-a4b0-46e380473065

	column year_month
		lineageTag: 62d638dc-eab7-452c-9979-5dff4c3c9f24
		summarizeBy: none
		isNameInferred
		sourceColumn: Dim_Date[year_month]

		annotation SummarizationSetBy = Automatic

	column category
		lineageTag: 3ed388cd-d5c7-4506-aaee-4568b4a77877
		summarizeBy: none
		isNameInferred
		sourceColumn: Dim_Products[category]

		annotation SummarizationSetBy = Automatic

	column Actual_y
		formatString: 0
		lineageTag: 612e048c-0f4b-474d-a780-b07e7f9c4d6b
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Actual_y]

		annotation SummarizationSetBy = Automatic

	partition Actual_Demand_Monthly = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    SUMMARIZE(
				        Fact_Transactions,
				        Dim_Date[Year_Month],       // Nhóm theo Tháng-Năm (từ bảng Date)
				        Dim_Products[category]      // Nhóm theo Danh mục (từ bảng Products)
				    ),
				    "Actual_y", 
				    CALCULATE(
				        COUNTROWS(Fact_Transactions), 
				        Fact_Transactions[status] IN {"Complete", "Shipped"} // Chỉ đếm các đơn hàng bán thành công
				    )
				)
				```

	annotation PBI_Id = 9b7f2a40c66941c09be5671fe6c892f1

