table Bridge_Traffic_Source
	lineageTag: 8684bf34-a800-40fa-8f7f-03db0094d7d0

	column traffic_source
		lineageTag: c267b086-a97b-482f-bec6-b459f445c7f1
		summarizeBy: none
		isNameInferred
		sourceColumn: [traffic_source]

		annotation SummarizationSetBy = Automatic

	partition Bridge_Traffic_Source = calculated
		mode: import
		source =
				
				DISTINCT(
				    FILTER(
				        UNION(
				            SELECTCOLUMNS(Traffic_Source_Performance, "traffic_source", Traffic_Source_Performance[traffic_source]),
				            SELECTCOLUMNS(Journey_Funnel_By_Source, "traffic_source", Journey_Funnel_By_Source[traffic_source])
				        ),
				        NOT ISBLANK([traffic_source])
				    )
				)

	annotation PBI_Id = 91c1a97ff5554c488ffb868288ef3a01

