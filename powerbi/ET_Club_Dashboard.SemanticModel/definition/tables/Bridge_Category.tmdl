table Bridge_Category
	lineageTag: 3994cde3-4746-4da1-8075-085624c7a2bc

	column category
		lineageTag: d4a761ff-9ccc-4fac-bacd-0a167e5c03cd
		summarizeBy: none
		isNameInferred
		sourceColumn: [category]

		annotation SummarizationSetBy = Automatic

	partition Bridge_Category = calculated
		mode: import
		source =
				
				DISTINCT(
				    FILTER(
				        UNION(
				            SELECTCOLUMNS(Dim_Products, "category", Dim_Products[category]),
				            SELECTCOLUMNS(Price_Band_Performance, "category", Price_Band_Performance[category]),
				            SELECTCOLUMNS(Inventory_ABC_Aging_By_Category_DC, "category", Inventory_ABC_Aging_By_Category_DC[product_category]),
				            SELECTCOLUMNS(Return_Cancel_Root_Cause_Proxy, "category", Return_Cancel_Root_Cause_Proxy[category]),
				            SELECTCOLUMNS(Demand_Forecast_12M, "category", Demand_Forecast_12M[category]),
				            SELECTCOLUMNS(Demand_Forecast_Evaluation, "category", Demand_Forecast_Evaluation[category])
				        ),
				        NOT ISBLANK([category])
				    )
				)

	annotation PBI_Id = 8e63ebf6358e46bc8e74042fd87f55ee

