table Bridge_Year
	lineageTag: a25b0ee8-6818-4e76-911c-4ecba0544fc7

	column year
		formatString: 0
		lineageTag: d6224234-2849-437a-8f63-e6dfee3163bf
		summarizeBy: none
		isNameInferred
		sourceColumn: [year]

		annotation SummarizationSetBy = Automatic

	partition Bridge_Year = calculated
		mode: import
		source =
				
				DISTINCT(
				    FILTER(
				        UNION(
				            SELECTCOLUMNS(Dim_Date, "year", Dim_Date[year]),
				            SELECTCOLUMNS(Status_Leakage_Analysis, "year", Status_Leakage_Analysis[year]),
				            SELECTCOLUMNS(Demand_Forecast_12M, "year", YEAR(Demand_Forecast_12M[ds]))
				        ),
				        NOT ISBLANK([year])
				    )
				)

	annotation PBI_Id = 17dd851edd854d468c67055918cfa3c9

