expression Source_Folder =
		let
		    Source = Folder.Files(dataLoadPath)
		in
		    Source
	lineageTag: 18e16713-fd8a-4577-bdc3-a7e3b1e6667d

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

expression fnLoadParquet =
		(FileName as text) as table =>
		let
		    Source = Source_Folder,
		    FileBinary = Table.SelectRows(Source, each [Name] = FileName){0}[Content],
		    Data = Parquet.Document(FileBinary)
		in
		    Data
	lineageTag: 54b30a57-f46c-4770-b1e8-1e5ac71ec8f5

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression fnLoadCsv =
		(FileName as text) as table =>
		let
		    Source = Source_Folder,
		    FileBinary = Table.SelectRows(Source, each [Name] = FileName){0}[Content],
		    Csv = Csv.Document(
		        FileBinary,
		        [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]
		    ),
		    Headers = Table.PromoteHeaders(Csv, [PromoteAllScalars=true])
		in
		    Headers
	lineageTag: 6a3212d1-8b1e-4af6-9632-4da6c07d9fdd

